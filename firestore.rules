rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'dasta10@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // BlogPost
    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'tag', 'excerpt', 'date', 'seed', 'createdAt', 'updatedAt', 'ownerId']) &&
             data.keys().size() == 8 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.tag is string && data.tag.size() <= 50 &&
             data.excerpt is string && data.excerpt.size() <= 500 &&
             data.date is string && data.date.size() <= 50 &&
             data.seed is string && data.seed.size() <= 50 &&
             data.ownerId == request.auth.uid;
    }

    match /blogPosts/{postId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming()) && incoming().createdAt == request.time;
      
      allow update: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'tag', 'excerpt', 'date', 'seed', 'updatedAt']);
                    
      allow delete: if isAdmin() && isValidId(postId);
    }

    // ProductConfig
    function isValidProductConfig(data) {
      return data.keys().hasAll(['fontDisplay', 'fontBody', 'updatedAt', 'ownerId']) &&
             data.keys().size() == 4 &&
             data.fontDisplay is string && data.fontDisplay.size() <= 50 &&
             data.fontBody is string && data.fontBody.size() <= 50 &&
             data.ownerId == request.auth.uid;
    }

    match /storeConfig/{configId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidId(configId) && isValidProductConfig(incoming());
      allow update: if isAdmin() && isValidId(configId) && isValidProductConfig(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['fontDisplay', 'fontBody', 'updatedAt']);
      allow delete: if isAdmin() && isValidId(configId);
    }
    
    // Product
    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'shippingPrice', 'extraPrice', 'imageUrl', 'createdAt', 'updatedAt', 'ownerId']) &&
             data.keys().size() == 9 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.price is number && data.shippingPrice is number && data.extraPrice is number &&
             data.imageUrl is string && data.imageUrl.size() <= 300 &&
             data.ownerId == request.auth.uid;
    }

    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'shippingPrice', 'extraPrice', 'imageUrl', 'updatedAt']);
      allow delete: if isAdmin() && isValidId(productId);
    }
    
    // Admins
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
